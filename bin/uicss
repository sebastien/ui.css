#!/usr/bin/env bash
BASE="$(dirname "$(dirname "$(readlink -f "$0")")")"
GUARD=""
EMBED=""
while [ "$#" -gt 0 ]; do
	case "$1" in
	--guard)
		GUARD="$2"
		shift 2
		;;
	--embed)
		EMBED="1"
		shift
		;;
	*)
		break
		;;
	esac
done

run_uicss() {
	local uicss_doc="$1"
	shift
	UICSS_BASE="$BASE" UICSS_GUARD="$GUARD" UICSS_EMBED="$EMBED" UICSS_DOC="$uicss_doc" bun -e '
const base = process.env.UICSS_BASE;
const guard = process.env.UICSS_GUARD;
const resolve = (mod) => typeof mod === "function" ? mod() : mod;
const render = (mod, scoped) => {
	const res = resolve(mod);
	return guard ? scoped(res, guard) : res;
};
const { default: css, guard: scoped, layers, docs } = await import(`${base}/src/js/uicss.js`);
const args = Bun.argv.slice(1);
if (process.env.UICSS_DOC === "1") {
	const res = {};
	for (const arg of args) {
		const { default: mod } = await import(`./${arg}`);
		res[arg] = [...docs(resolve(mod))];
	}
	console.log(JSON.stringify(res));
} else if (args.length === 0) {
	const { default: all } = await import(`${base}/src/css/all.js`);
	console.log([...css(guard ? all(undefined, { guard }) : all())].join("\n"));
} else if (args.length === 1) {
	const { default: mod } = await import(`./${args[0]}`);
	console.log([...css(render(mod, scoped))].join("\n"));
} else {
	const res = {};
	for (const arg of args) {
		const { default: mod } = await import(`./${arg}`);
		res[arg.split(".").at(0)] = render(mod, scoped);
	}
	console.log([...css(layers(res))].join("\n"));
}
' "$@"
}

case $1 in
-d | --doc)
	shift
	if ! run_uicss 1 "$@"; then
		echo "!!! ERR Could not process: $@"
	fi
	;;
*)
	if [ -z "$1" ]; then
		run_uicss 0
	else
		run_uicss 0 "$@"
	fi
	;;
esac
# EOF
